# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git

# Google Gemini API (get from aistudio.google.com)
GOOGLE_API_KEY=

# ElevenLabs credentials (get from elevenlabs.io)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...

# Optional: refinement loop thresholds
MAX_ITERATIONS=5
PASS_THRESHOLD=8.0

# Optional: database (defaults to techmellon.db in project root)
DB_PATH=techmellon.db
