        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Booking reference number"
          },
          "extra_type": {
            "type": "string",
            "description": "Type of extra: 'baggage', 'meal', or 'seat_selection'"
          },
          "quantity": {
            "type": "integer",
            "description": "Quantity of the extra (optional, defaults to 1)"
          }
        },
        "required": ["ref", "extra_type"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "add_assistance",
      "description": "Add special assistance requests to a booking. Types include wheelchair, unaccompanied minor, or pet transport.",
      "parameters": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Booking reference number"
          },
          "assistance_type": {
            "type": "string",
            "description": "Type of assistance: 'wheelchair', 'unaccompanied_minor', 'pet_transport', etc."
          }
        },
        "required": ["ref", "assistance_type"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "get_flight_status",
      "description": "Get the current status of a flight. Returns status (on-time, delayed, cancelled) and any relevant details.",
      "parameters": {
        "type": "object",
        "properties": {
          "flight_id": {
            "type": "string",
            "description": "Flight ID to check status for"
          }
        },
        "required": ["flight_id"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "get_policy",
      "description": "Retrieve airline policies. Types include baggage, pet, cancellation, checkin, and special assistance policies.",
      "parameters": {
        "type": "object",
        "properties": {
          "policy_type": {
            "type": "string",
            "description": "Type of policy: 'baggage', 'pet', 'cancellation', 'checkin', or 'assistance'"
          }
        },
        "required": ["policy_type"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    }
  ]
