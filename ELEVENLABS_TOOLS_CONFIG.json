{
  "tools": [
    {
      "tool_name": "search_flights",
      "description": "Search for available flights based on criteria like destination, date, and seat class. Returns list of available flights with prices and times.",
      "parameters": {
        "type": "object",
        "properties": {
          "destination": {
            "type": "string",
            "description": "Destination city or code (e.g., 'Tokyo', 'TYO', 'Paris')"
          },
          "date": {
            "type": "string",
            "description": "Travel date in YYYY-MM-DD format (optional)"
          },
          "seat_class": {
            "type": "string",
            "description": "Seat class: 'economy', 'business', or 'first' (optional, defaults to economy)"
          }
        },
        "required": ["destination"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "book_flight",
      "description": "Book a flight for a customer. Requires flight ID, passenger name, and email. Returns booking confirmation with booking reference.",
      "parameters": {
        "type": "object",
        "properties": {
          "flight_id": {
            "type": "string",
            "description": "ID of the flight to book"
          },
          "passenger_name": {
            "type": "string",
            "description": "Full name of the passenger"
          },
          "email": {
            "type": "string",
            "description": "Email address of the passenger"
          },
          "seat_class": {
            "type": "string",
            "description": "Seat class: 'economy', 'business', or 'first' (optional)"
          }
        },
        "required": ["flight_id", "passenger_name", "email"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "get_booking",
      "description": "Retrieve booking details by booking reference number. Returns booking information including flight details, passenger info, and status.",
      "parameters": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Booking reference number"
          }
        },
        "required": ["ref"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "cancel_booking",
      "description": "Cancel an existing booking. Returns refund amount and confirmation.",
      "parameters": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Booking reference number to cancel"
          }
        },
        "required": ["ref"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "reschedule_booking",
      "description": "Reschedule a booking to a different flight. Returns new booking reference and any applicable fees.",
      "parameters": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Current booking reference number"
          },
          "new_flight_id": {
            "type": "string",
            "description": "ID of the new flight to reschedule to"
          }
        },
        "required": ["ref", "new_flight_id"]
      },
      "webhook": {
        "url": "https://semiacidified-pansophistically-charmain.ngrok-free.dev/webhook/elevenlabs",
        "method": "POST"
      }
    },
    {
      "tool_name": "add_extras",
